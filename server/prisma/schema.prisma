generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum Brand {
  SAMSUNG
  HONOR
  TECHNO
  INFINIX
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  username     String   @unique
  password     String
  phoneNumber  String   @default("0000000000")
  role         Role     @default(USER)
  avatar       String   @default("https://ui-avatars.com/api/?name=User&background=random")
  
  // --- NEW COLUMNS FOR PUSH & SECURITY ---
  pushToken    String?  // The Firebase address for this phone
  deviceId     String?  // The unique ID to skip OTP on "Trusted Devices"
  
  createdAt    DateTime @default(now())

  // Relation to track which notifications this user has read
  readNotifications NotificationRead[]
}

model Phone {
  id          String   @id // Manual ID (not automatic)
  brand       Brand    @default(SAMSUNG)
  name        String
  price       Float
  lastUpdated DateTime @updatedAt
}

model Notification {
  id      Int    @id @default(autoincrement())
  message String
  createdAt DateTime @default(now())

  // Relation to see which users have read this specific notification
  readBy  NotificationRead[]
}

// --- NEW JOIN TABLE FOR RED DOT LOGIC ---
model NotificationRead {
  id             Int          @id @default(autoincrement())
  userId         Int
  notificationId Int
  readAt         DateTime     @default(now())

  // Connections
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  // Ensure a user can't "read" the same notification twice in the database
  @@unique([userId, notificationId])
}